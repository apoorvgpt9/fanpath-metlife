# Required environment variables for fanpath-metlife.
# Copy to .env and fill in real values locally. Do NOT commit .env.

# Gemini API key (Intent + Guide agents).
GEMINI_API_KEY=your-gemini-api-key-here

# Shared bearer token for staff closure endpoints. Rotate per deploy.
STAFF_TOKEN=change-me-to-a-long-random-value

# GCP / Firebase project id.
FIREBASE_PROJECT_ID=your-firebase-project-id-here

# CORS: comma-separated list of allowed origins. Use "*" for local dev only.
ALLOWED_ORIGIN=*
